# =============================================================================
# .env — Runtime toggles for the Splunk Client
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Uncomment and change any values you want to override
#   3. Leave lines commented out to use the safe defaults
#
# CREDENTIALS (SPLUNK_HOST and SPLUNK_TOKEN) are set in:
#   splunk_client/settings.py
# Not here. The .env file is only for runtime behaviour toggles.
#
# NEVER commit .env to Git — it is blocked by .gitignore.
# =============================================================================


# =============================================================================
# AUTH MODE
# Controls where the tool looks for credential overrides.
#
#   dotenv  -> reads this .env file for any overrides (default, local Mac use)
#   env     -> reads OS environment variables only (GitLab/GitHub CI/CD)
#
# Leave as "dotenv" for normal local use.
# =============================================================================
AUTH_MODE=dotenv


# =============================================================================
# OPTIONAL OVERRIDES
# Uncomment a line to override the default value.
# Useful if you have multiple Splunk hosts or users with different settings.
# =============================================================================

# Override the host from settings.py (useful for switching between environments)
# SPLUNK_HOST=other-org.splunkcloud.com

# Override the token from settings.py (useful for per-user tokens in a shared repo)
# SPLUNK_TOKEN=paste-override-token-here

# Splunk REST API port (default: 8089, only change for self-hosted Enterprise)
# SPLUNK_PORT=8089

# SSL certificate verification.
# If connecting to localhost or a Splunk instance with a self-signed certificate,
# set this to false. Leave as true for Splunk Cloud or any production instance.
#
# Self-signed cert error looks like:
#   SSL: CERTIFICATE_VERIFY_FAILED certificate verify failed: self-signed certificate
# Fix: uncomment the line below
# SPLUNK_VERIFY_SSL=false
#
# Default (Splunk Cloud / trusted cert):
# SPLUNK_VERIFY_SSL=true

# HTTP request timeout in seconds
# SPLUNK_TIMEOUT=30

# Seconds between job status poll requests
# SPLUNK_JOB_POLL_INTERVAL=3

# Maximum seconds to wait for a search job before timing out
# SPLUNK_JOB_MAX_WAIT=120

# Folder where CSV results are saved (relative to the project folder)
# RESULTS_DIR=search_results
